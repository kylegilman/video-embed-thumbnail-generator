{
	"name": "videopack-admin",
	"version": "0.2.0",
	"description": "Videopack plugin admin and blocks.",
	"author": "kylegilman",
	"license": "GPL-2.0-or-later",
	"main": "build/videopack-video.js",
	"scripts": {
		"build": "wp-scripts build && npm run build:skin",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"start": "wp-scripts start",
		"start:all": "wp-scripts start & npm run watch:skin",
		"packages-update": "wp-scripts packages-update",
		"build:skin": "npx sass ../video-js/skins/vjs-theme-videopack.scss ../video-js/skins/vjs-theme-videopack.css --style=compressed --no-source-map",
		"watch:skin": "npx sass --watch ../video-js/skins/vjs-theme-videopack.scss ../video-js/skins/vjs-theme-videopack.css --no-source-map"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@wordpress/api-fetch": "^7.44.0",
		"@wordpress/blocks": "^15.17.0",
		"@wordpress/core-data": "^7.44.0",
		"@wordpress/dataviews": "^14.1.0",
		"@wordpress/i18n": "^6.17.0",
		"@wordpress/icons": "^12.2.0",
		"@wordpress/media-utils": "^5.44.0",
		"video.js": "^8.23.4"
	},
	"devDependencies": {
		"@wordpress/base-styles": "^6.20.0",
		"@wordpress/eslint-plugin": "^25.0.0",
		"@wordpress/scripts": "^32.0.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"overrides": {
		"react-autosize-textarea": {
			"react": "$react",
			"react-dom": "$react-dom"
		}
	}
}
