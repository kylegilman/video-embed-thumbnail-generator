{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "videopack/video-caption",
  "title": "Video Caption",
  "category": "media",
  "parent": [
    "videopack/videopack-video",
    "videopack/video-loop"
  ],
  "icon": "text",
  "description": "Add a caption to your video.",
  "usesContext": [
    "postId",
    "postType",
    "videopack/postId",
    "videopack/parentPostId",
    "videopack/prioritizePostData",
    "videopack/caption"
  ],
  "attributes": {
    "caption": {
      "type": "string"
    }
  },
  "supports": {
    "html": false,
    "reusable": false,
    "multiple": true,
    "interactivity": {
      "clientNavigation": true
    }
  },
  "textdomain": "video-embed-thumbnail-generator",
  "editorScript": "file:./index.js"
}