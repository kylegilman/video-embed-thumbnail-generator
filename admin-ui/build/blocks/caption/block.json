{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "videopack/caption",
  "title": "Videopack Caption",
  "category": "media",
  "parent": [
    "videopack/player-container",
    "videopack/loop"
  ],
  "icon": "text",
  "description": "Add a caption to your video.",
  "usesContext": [
    "postId",
    "postType"
  ],
  "attributes": {
    "caption": {
      "type": "string"
    },
    "isPreview": {
      "type": "boolean",
      "default": false
    }
  },
  "example": {
    "attributes": {
      "isPreview": true
    }
  },
  "supports": {
    "html": false,
    "reusable": false,
    "multiple": true,
    "interactivity": {
      "clientNavigation": true
    }
  },
  "textdomain": "video-embed-thumbnail-generator",
  "editorScript": "file:./index.js"
}