{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "videopack/video-caption",
	"title": "Video Caption",
	"category": "media",
	"parent": ["videopack/videopack-video"],
	"icon": "editor-alignleft",
	"description": "Caption field for the video player.",
	"attributes": {
		"caption": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"reusable": false,
		"multiple": false
	},
	"textdomain": "video-embed-thumbnail-generator",
	"editorScript": "file:./index.js"
}
