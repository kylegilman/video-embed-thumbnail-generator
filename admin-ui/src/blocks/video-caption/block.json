{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "videopack/video-caption",
	"title": "Video Caption",
	"category": "media",
	"parent": ["videopack/videopack-video"],
	"icon": "text",
	"description": "Add a caption to your video.",
	"attributes": {
		"caption": {
			"type": "string"
		}
	},
	"supports": {
		"html": false,
		"reusable": false,
		"multiple": true,
		"interactivity": {
			"clientNavigation": true
		}
	},
	"textdomain": "video-embed-thumbnail-generator",
	"editorScript": "file:./index.js"
}
