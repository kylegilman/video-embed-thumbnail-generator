{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "videopack/play-button",
	"title": "Play Button",
	"category": "media",
	"icon": "controls-play",
	"description": "Displays a play button overlay.",
	"usesContext": [
		"videopack/skin"
	],
	"attributes": {
		"play_button_color": {
			"type": "string"
		},
		"play_button_secondary_color": {
			"type": "string"
		}
	},
	"supports": {
		"html": false
	},
	"textdomain": "video-embed-thumbnail-generator",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css"
}
